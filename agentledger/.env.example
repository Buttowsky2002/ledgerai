# LedgerAI — example environment file.
#
# Copy to `.env` (next to docker-compose.yml) and edit. Docker Compose loads it
# automatically. EVERYTHING HERE IS OPTIONAL FOR THE DEMO: `make demo` works with
# this file empty/absent — no provider keys required.
#
# NEVER commit a real secret. Values here are placeholders only. See
# docs/ENVIRONMENT.md for the full per-service variable reference and
# docs/DEPLOYMENT.md for demo / gateway-dev / production modes.

# ──────────────────────────────────────────────────────────────────────────────
# Provider keys — only needed if you route REAL traffic through the gateway
# (gateway-dev or production). Leave blank for the demo and the smoke test
# (the smoke test uses a built-in mock upstream).
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Optional integrations (blank = feature disabled / no-op). These names match what
# the dev docker-compose.yml reads.
# ──────────────────────────────────────────────────────────────────────────────
# Slack budget/risk alerts — incoming webhook URL (blank = alerting off).
AGENTLEDGER_SLACK_WEBHOOK_URL=
# GitHub outcome connector — a read-only PAT (blank = connector idle).
GITHUB_TOKEN=
# LiteLLM adapter default tenant (UUID) for ingested spend logs.
AGENTLEDGER_ADAPTER_TENANT=
# Semantic risk-enrichment tier (opt-in, async). Needs ANTHROPIC_API_KEY when on.
AGENTLEDGER_RISK_ENRICH_ENABLED=false
AGENTLEDGER_RISK_ENRICH_MODEL=claude-opus-4-8

# ──────────────────────────────────────────────────────────────────────────────
# Production self-host secrets — REQUIRED in production, placeholders only here.
# The dev docker-compose.yml uses throwaway dev defaults instead of these, so they
# do not affect the demo. Generate strong random values and inject via your secret
# manager (do NOT put real values in a committed file). Both the LEDGERAI_* names
# below and the deprecated AGENTLEDGER_* aliases are accepted.
# ──────────────────────────────────────────────────────────────────────────────
# Session-JWT signing secret (HS256). Generate, e.g.: openssl rand -hex 32
LEDGERAI_JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
# Postgres DSN for the API — use the least-privilege agentledger_api role.
LEDGERAI_PG_DSN=postgres://agentledger_api:CHANGE_ME_DB_PASSWORD@postgres:5432/agentledger?sslmode=require
# ClickHouse connection for analytics.
LEDGERAI_CLICKHOUSE_URL=http://clickhouse:8123
LEDGERAI_CLICKHOUSE_DB=agentledger
LEDGERAI_CLICKHOUSE_USER=ledgerai
LEDGERAI_CLICKHOUSE_PASSWORD=CHANGE_ME_CLICKHOUSE_PASSWORD
# Gateway ops endpoints (/v1/usage, /metrics) bearer token (see ops auth).
LEDGERAI_OPS_TOKEN=CHANGE_ME_OPS_TOKEN
# Swagger docs in production: opt in + protect with a bearer token.
LEDGERAI_EXPOSE_DOCS=false
LEDGERAI_DOCS_TOKEN=CHANGE_ME_DOCS_TOKEN
# Budget behavior on a Redis outage: open (keep serving) | closed (reject).
LEDGERAI_BUDGET_FAIL_MODE=open

# OIDC SSO (per provider; blank = provider unavailable). Client SECRETS are passed
# by env-var NAME elsewhere — never inline a secret value here.
LEDGERAI_OIDC_REDIRECT_BASE=https://app.example.com
# AGENTLEDGER_OIDC_GOOGLE_CLIENT_ID=
# AGENTLEDGER_OIDC_GOOGLE_CLIENT_SECRET=
# AGENTLEDGER_OIDC_MICROSOFT_CLIENT_ID=
# AGENTLEDGER_OIDC_MICROSOFT_CLIENT_SECRET=

# NOTE: do NOT set LEDGERAI_DEV_TRUST_HEADER in production — it is a dev-only auth
# bypass and the API refuses to start in production if it is enabled.
