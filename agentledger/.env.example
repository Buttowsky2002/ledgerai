# BadgerIQ — example environment file.
#
# Copy to `.env` (next to docker-compose.yml) and edit. Docker Compose loads it
# automatically. EVERYTHING HERE IS OPTIONAL FOR THE DEMO: `make demo` works with
# this file empty/absent — no provider keys required.
#
# NEVER commit a real secret. Values here are placeholders only. See
# docs/ENVIRONMENT.md for the full per-service variable reference and
# docs/DEPLOYMENT.md for demo / gateway-dev / production modes.

# ──────────────────────────────────────────────────────────────────────────────
# Provider keys — only needed if you route REAL traffic through the gateway
# (gateway-dev or production). Leave blank for the demo and the smoke test
# (the smoke test uses a built-in mock upstream).
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Optional integrations (blank = feature disabled / no-op). These names match what
# the dev docker-compose.yml reads.
# ──────────────────────────────────────────────────────────────────────────────
# Slack budget/risk alerts — incoming webhook URL (blank = alerting off).
AGENTLEDGER_SLACK_WEBHOOK_URL=
# GitHub outcome connector — a read-only PAT (blank = connector idle).
GITHUB_TOKEN=
# LiteLLM adapter default tenant (UUID) for ingested spend logs.
AGENTLEDGER_ADAPTER_TENANT=
# Dashboard: false hides the demo banner; pair with `make reset-demo` to drop synthetic analytics.
BADGERIQ_DEMO_MODE=false
# Dev tenant header (must match where connectors/imports are registered).
BADGERIQ_DEV_TENANT_ID=00000000-0000-4000-8000-000000000001
# Keep BFF auth when the standalone image runs NODE_ENV=production (local docker).
BADGERIQ_DEV_TRUST_TENANT=true
# Design partner onboard API (dev/demo only — registers agents + seeds outcome graph).
BADGERIQ_DESIGN_PARTNER_ONBOARD_ENABLED=false
# Attribution worker URL for on-demand POST /run after onboard (docker: http://attribution:8096).
BADGERIQ_ATTRIBUTION_WORKER_URL=http://localhost:8096
# Allow attribution worker POST /run trigger (dev compose sets this true).
BADGERIQ_ATTR_ALLOW_TRIGGER=false
# Connector auto-sync: poll Postgres for due connectors and pull recent spend (default: enabled).
# BADGERIQ_CONNECTOR_SCHEDULER_ENABLED=true
# How often the scheduler wakes to check for due connectors (default: 5 minutes).
# BADGERIQ_CONNECTOR_SCHEDULER_INTERVAL_MS=300000
# Copilot auto-sync uses the same pattern (default: enabled, 5-minute check interval).
# BADGERIQ_COPILOT_SCHEDULER_ENABLED=true
# BADGERIQ_COPILOT_SCHEDULER_INTERVAL_MS=300000
# Dashboard overview auto-refresh while the page is open (milliseconds; 0 = off).
# BADGERIQ_DASHBOARD_LIVE_REFRESH_MS=30000
# Semantic risk-enrichment tier (opt-in, async). Needs ANTHROPIC_API_KEY when on.
AGENTLEDGER_RISK_ENRICH_ENABLED=false
AGENTLEDGER_RISK_ENRICH_MODEL=claude-opus-4-8

# ──────────────────────────────────────────────────────────────────────────────
# Production self-host secrets — REQUIRED in production, placeholders only here.
# The dev docker-compose.yml uses throwaway dev defaults instead of these, so they
# do not affect the demo. Generate strong random values and inject via your secret
# manager (do NOT put real values in a committed file). BADGERIQ_* names are
# preferred; LEDGERAI_* and AGENTLEDGER_* aliases are still accepted.
# ──────────────────────────────────────────────────────────────────────────────
# Session-JWT signing secret (HS256). Generate, e.g.: openssl rand -hex 32
# (the unprefixed JWT_SECRET is also accepted — Cloud Run MVP convention)
BADGERIQ_JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
# Postgres DSN for the API — use the least-privilege agentledger_api role.
# Alternatively set the discrete DB_HOST / DB_NAME / DB_USER / DB_PASSWORD
# (+ optional DB_PORT, DB_SSLMODE) — DB_HOST may be a /cloudsql/... unix socket.
BADGERIQ_PG_DSN=postgres://agentledger_api:CHANGE_ME_DB_PASSWORD@postgres:5432/agentledger?sslmode=require
# Analytics backend: clickhouse (default, full stack) | postgres (Cloud Run MVP,
# single database — requires deploy/postgres/023_analytics_mvp.sql; see Dockerfile.mvp).
BADGERIQ_ANALYTICS_BACKEND=clickhouse
# ClickHouse connection for analytics (unused when BADGERIQ_ANALYTICS_BACKEND=postgres).
BADGERIQ_CLICKHOUSE_URL=http://clickhouse:8123
BADGERIQ_CLICKHOUSE_DB=agentledger
BADGERIQ_CLICKHOUSE_USER=ledgerai
BADGERIQ_CLICKHOUSE_PASSWORD=CHANGE_ME_CLICKHOUSE_PASSWORD
# Gateway ops endpoints (/v1/usage, /metrics) bearer token (see ops auth).
BADGERIQ_OPS_TOKEN=CHANGE_ME_OPS_TOKEN
# Swagger docs in production: opt in + protect with a bearer token.
BADGERIQ_EXPOSE_DOCS=false
BADGERIQ_DOCS_TOKEN=CHANGE_ME_DOCS_TOKEN
# Budget behavior on a Redis outage: open (keep serving) | closed (reject).
BADGERIQ_BUDGET_FAIL_MODE=open

# OIDC SSO (per provider; blank = provider unavailable). Client SECRETS are passed
# by env-var NAME elsewhere — never inline a secret value here.
BADGERIQ_OIDC_REDIRECT_BASE=https://app.example.com
# AGENTLEDGER_OIDC_GOOGLE_CLIENT_ID=
# AGENTLEDGER_OIDC_GOOGLE_CLIENT_SECRET=
# AGENTLEDGER_OIDC_MICROSOFT_CLIENT_ID=
# AGENTLEDGER_OIDC_MICROSOFT_CLIENT_SECRET=

# NOTE: do NOT set BADGERIQ_DEV_TRUST_HEADER in production — it is a dev-only auth
# bypass and the API refuses to start in production if it is enabled.

# ──────────────────────────────────────────────────────────────────────────────
# Legacy env var aliases (deprecated — use BADGERIQ_* above instead)
# Services resolve BADGERIQ_* → LEDGERAI_* → AGENTLEDGER_* (gateway: BADGERIQ_* → LEDGERAI_*).
# Uncomment only if migrating an older deployment; do not set both prefixes for one value.
# ──────────────────────────────────────────────────────────────────────────────
# LEDGERAI_JWT_SECRET=
# LEDGERAI_PG_DSN=
# LEDGERAI_CLICKHOUSE_URL=
# LEDGERAI_CLICKHOUSE_PASSWORD=
# LEDGERAI_OPS_TOKEN=
# AGENTLEDGER_PG_DSN=
# AGENTLEDGER_CLICKHOUSE_URL=
