{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentledger.ai/schemas/events/normalized_usage_event.schema.json",
  "title": "NormalizedUsageEvent",
  "description": "Shared usage event shape emitted by API connectors before import into llm_calls.",
  "type": "object",
  "required": ["provider", "timestamp"],
  "properties": {
    "provider": { "type": "string" },
    "platformDisplayName": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "model": { "type": "string" },
    "requestCount": { "type": "integer", "minimum": 0 },
    "inputTokens": { "type": "integer", "minimum": 0 },
    "outputTokens": { "type": "integer", "minimum": 0 },
    "totalTokens": { "type": "integer", "minimum": 0 },
    "costUsd": { "type": "number", "minimum": 0 },
    "costSource": { "type": "string" },
    "status": { "type": "string" },
    "providerUserId": { "type": "string" },
    "userEmail": { "type": "string" },
    "userName": { "type": "string" },
    "apiKeyId": { "type": "string" },
    "apiKeyName": { "type": "string" },
    "projectId": { "type": "string" },
    "projectName": { "type": "string" },
    "workspaceId": { "type": "string" },
    "workspaceName": { "type": "string" },
    "organizationId": { "type": "string" },
    "organizationName": { "type": "string" },
    "serviceAccountId": { "type": "string" },
    "serviceAccountName": { "type": "string" },
    "teamId": { "type": "string" },
    "teamName": { "type": "string" },
    "providerReportedCost": { "type": "number", "minimum": 0 },
    "currency": { "type": "string" },
    "billingPeriod": { "type": "string" },
    "usageDate": { "type": "string" },
    "modelPricingRef": { "type": "string" }
  },
  "additionalProperties": true
}
