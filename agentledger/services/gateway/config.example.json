{
  "listen_addr": ":8080",
  "price_book_path": "../../pricing/pricebook.json",
  "providers": [
    {
      "name": "openai",
      "base_url": "https://api.openai.com",
      "api_key_env": "OPENAI_API_KEY",
      "model_prefixes": ["gpt-", "o3", "o4"]
    },
    {
      "name": "anthropic",
      "base_url": "https://api.anthropic.com",
      "api_key_env": "ANTHROPIC_API_KEY",
      "model_prefixes": ["claude-"]
    }
  ],
  "virtual_keys": [
    {
      "key": "alk_dev_engineering",
      "tenant_id": "00000000-0000-0000-0000-000000000001",
      "team_id": "engineering",
      "user_id": "dev@example.com",
      "app_id": "support-copilot",
      "environment": "dev",
      "allowed_models": ["gpt-4o*", "claude-*"],
      "monthly_budget_usd": 250,
      "rate_limit_rpm": 120,
      "dlp_policy_id": "default-redact"
    }
  ],
  "dlp": {
    "fail_mode": "open",
    "policies": [
      { "id": "default-redact", "action": "redact", "classes": ["credentials", "pci"] },
      { "id": "audit-only", "action": "log" },
      { "id": "strict-block", "action": "block", "classes": ["credentials", "pci", "pii"] }
    ]
  },
  "_comment_agent_tool_allow": "Per-agent tool/MCP allowlist enforced inline (ADR-032). An agent listed here is deny-by-default: any declared tool/MCP server not in its entries is blocked. Agents NOT listed are ungoverned (allowed; the async risk worker still scores them). Usually loaded from Postgres agent_tool_allowlist via AGENTLEDGER_PG_DSN rather than set here.",
  "agent_tool_allow": [
    { "tenant_id": "00000000-0000-0000-0000-000000000001", "agent_id": "00000000-0000-0000-0000-0000000000a1", "tool_name": "web_search" },
    { "tenant_id": "00000000-0000-0000-0000-000000000001", "agent_id": "00000000-0000-0000-0000-0000000000a1", "tool_name": "list_issues", "mcp_server": "github" }
  ],
  "events": {
    "type": "file",
    "path": "events.ndjson",
    "flush_ms": 500,
    "buffer_size": 4096
  },
  "redis": {
    "addr": "",
    "password_env": "AGENTLEDGER_REDIS_PASSWORD",
    "db": 0
  }
}
