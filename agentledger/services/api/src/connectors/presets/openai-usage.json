{
  "name": "OpenAI Usage API",
  "provider": "openai",
  "category": "provider_spend",
  "authType": "bearer_token",
  "baseUrl": "https://api.openai.com",
  "endpoints": [
    {
      "path": "/v1/organization/costs",
      "method": "GET",
      "queryParams": {
        "start_time": "{{sync_start_unix}}",
        "end_time": "{{sync_end_unix}}",
        "bucket_width": "1d",
        "limit": "31",
        "group_by[]": "line_item"
      }
    }
  ],
  "pagination": {
    "type": "response_token",
    "itemsPath": "data",
    "flattenPath": "results",
    "tokenPath": "next_page",
    "tokenParam": "page",
    "pageSize": 31,
    "limitParam": "limit",
    "maxPages": 20
  },
  "rateLimit": {
    "requestsPerMinute": 60
  },
  "retry": {
    "maxAttempts": 3,
    "retryOn": [429, 500, 502, 503, 504]
  },
  "destinationRecordType": "spend_usage_record",
  "fieldMappings": [
    { "type": "fallback", "target": "cost_usd", "sources": ["amount.value", "cost_usd", "cost"] },
    { "type": "direct", "source": "amount.currency", "target": "currency" },
    { "type": "direct", "source": "line_item", "target": "model" },
    { "type": "direct", "source": "line_item", "target": "product" },
    { "type": "direct", "source": "project_id", "target": "project_id" },
    { "type": "fallback", "target": "id", "sources": ["line_item", "project_id", "start_time"] },
    { "type": "constant", "target": "provider", "value": "openai" },
    { "type": "constant", "target": "platform_display_name", "value": "OpenAI" },
    { "type": "fallback", "target": "ts", "sources": ["start_time", "end_time"] },
    { "type": "fallback", "target": "period_start", "sources": ["start_time"] },
    { "type": "fallback", "target": "period_end", "sources": ["end_time"] },
    { "type": "direct", "source": "n_context_tokens_total", "target": "input_tokens" },
    { "type": "direct", "source": "n_generated_tokens_total", "target": "output_tokens" }
  ],
  "validationRules": [
    { "field": "model", "required": false, "type": "string" },
    { "field": "cost_usd", "required": false, "type": "currency" }
  ],
  "dedupe": {
    "strategy": "period_model_user_product_cost",
    "fields": ["model", "ts", "project_id", "cost_usd", "product"]
  },
  "schedule": {
    "intervalMinutes": 60,
    "enabled": true
  },
  "capabilities": {
    "supportsUsage": true,
    "supportsBilling": true,
    "supportsUsers": true,
    "supportsProjects": true,
    "supportsWorkspaces": false,
    "supportsApiKeys": true,
    "supportsUserLevelCost": false,
    "supportsModelLevelUsage": true
  }
}
