{
  "name": "Cursor Admin API (usage + code activity)",
  "provider": "cursor",
  "category": "coding_tool",
  "authType": "basic_auth",
  "baseUrl": "https://api.cursor.com",
  "endpoints": [
    {
      "path": "/teams/filtered-usage-events",
      "method": "POST",
      "bodyTemplate": "{\"startDate\":{{sync_start_unix_ms}},\"endDate\":{{sync_end_unix_ms}},\"page\":{{page}},\"pageSize\":{{page_size}}}"
    }
  ],
  "pagination": {
    "type": "page",
    "itemsPath": "usageEvents",
    "hasMorePath": "pagination.hasNextPage",
    "pageSize": 100,
    "maxPages": 500
  },
  "rateLimit": {
    "requestsPerMinute": 20
  },
  "retry": {
    "maxAttempts": 3,
    "baseDelayMs": 2000,
    "maxDelayMs": 30000,
    "retryOn": [429, 500, 502, 503, 504]
  },
  "syncRange": {
    "maxDaysPerRequest": 30,
    "defaultBackfillDays": 90
  },
  "destinationRecordType": "spend_usage_record",
  "capabilities": {
    "supportsUsage": true,
    "supportsBilling": true,
    "supportsUsers": true,
    "supportsProjects": false,
    "supportsWorkspaces": false,
    "supportsApiKeys": false,
    "supportsUserLevelCost": true,
    "supportsModelLevelUsage": true
  },
  "fieldMappings": [
    { "type": "direct", "source": "timestamp", "target": "ts" },
    { "type": "direct", "source": "userEmail", "target": "user_email" },
    { "type": "direct", "source": "userEmail", "target": "user_id" },
    { "type": "direct", "source": "model", "target": "model" },
    { "type": "direct", "source": "kind", "target": "product" },
    { "type": "direct", "source": "isChargeable", "target": "is_chargeable" },
    { "type": "direct", "source": "chargedCents", "target": "amount_cents" },
    { "type": "derived", "target": "cost_usd", "expression": "amount_cents / 100" },
    { "type": "fallback", "target": "input_tokens", "sources": ["tokenUsage.inputTokens"] },
    { "type": "fallback", "target": "output_tokens", "sources": ["tokenUsage.outputTokens"] },
    {
      "type": "fallback",
      "target": "id",
      "sources": ["timestamp", "userEmail", "model", "chargedCents", "kind"]
    },
    { "type": "constant", "target": "provider", "value": "cursor" },
    { "type": "constant", "target": "platform_display_name", "value": "Cursor" }
  ],
  "validationRules": [
    { "field": "cost_usd", "type": "currency", "required": true, "min": 0 },
    { "field": "user_email", "type": "string", "required": true }
  ],
  "dedupe": {
    "strategy": "custom",
    "fields": ["ts", "user_email", "model", "product"]
  },
  "companionFetches": [
    {
      "id": "codingActivity",
      "destinationRecordType": "coding_activity_record",
      "endpoint": {
        "path": "/teams/daily-usage-data",
        "method": "POST",
        "bodyTemplate": "{\"startDate\":{{sync_start_unix_ms}},\"endDate\":{{sync_end_unix_ms}}}"
      },
      "pagination": {
        "type": "page",
        "itemsPath": "data",
        "pageSize": 100,
        "maxPages": 500
      },
      "fieldMappings": [
        { "type": "direct", "source": "email", "target": "user_email" },
        { "type": "direct", "source": "email", "target": "user_id" },
        { "type": "direct", "source": "acceptedLinesAdded", "target": "acceptedLinesAdded" },
        { "type": "direct", "source": "acceptedLinesDeleted", "target": "acceptedLinesDeleted" },
        {
          "type": "derived",
          "target": "lines_accepted",
          "expression": "acceptedLinesAdded + acceptedLinesDeleted"
        },
        { "type": "direct", "source": "totalLinesAdded", "target": "lines_added" },
        { "type": "direct", "source": "totalLinesDeleted", "target": "lines_deleted" },
        { "type": "direct", "source": "totalLinesAdded", "target": "lines_committed" },
        { "type": "direct", "source": "totalTabsAccepted", "target": "tabs_accepted" },
        { "type": "direct", "source": "composerRequests", "target": "composer_requests" },
        { "type": "direct", "source": "chatRequests", "target": "chat_requests" },
        { "type": "fallback", "target": "ts", "sources": ["date", "day"] },
        {
          "type": "fallback",
          "target": "id",
          "sources": ["day", "date", "email", "userId"]
        },
        { "type": "constant", "target": "provider", "value": "cursor" },
        { "type": "constant", "target": "tool_name", "value": "cursor-usage" },
        { "type": "constant", "target": "platform_display_name", "value": "Cursor" }
      ],
      "validationRules": [
        { "field": "user_email", "type": "string", "required": true }
      ],
      "dedupe": {
        "strategy": "custom",
        "fields": ["ts", "user_email", "tool_name"]
      }
    }
  ],
  "schedule": {
    "intervalMinutes": 60,
    "enabled": true
  }
}
