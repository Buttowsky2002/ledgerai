{
  "name": "Anthropic Spend API",
  "provider": "anthropic",
  "category": "provider_spend",
  "authType": "api_key_header",
  "authHeaderName": "x-api-key",
  "baseUrl": "https://api.anthropic.com",
  "endpoints": [
    {
      "path": "/v1/organizations/analytics/cost/list_by_user",
      "method": "GET",
      "queryParams": {
        "starting_at": "{{sync_start_day}}",
        "ending_at": "{{sync_end_day}}",
        "bucket_width": "1d",
        "limit": "31",
        "group_by[]": "model"
      }
    }
  ],
  "headers": {
    "anthropic-version": "2023-06-01"
  },
  "pagination": {
    "type": "response_token",
    "itemsPath": "data",
    "tokenPath": "next_page",
    "tokenParam": "page",
    "pageSize": 31,
    "limitParam": "limit",
    "maxPages": 1
  },
  "rateLimit": {
    "requestsPerSecond": 0.33,
    "retryAfterHeader": "retry-after"
  },
  "retry": {
    "maxAttempts": 4,
    "baseDelayMs": 2000,
    "maxDelayMs": 60000,
    "retryOn": [500, 502, 503, 504]
  },
  "destinationRecordType": "spend_usage_record",
  "fieldMappings": [
    { "type": "direct", "source": "actor.user_id", "target": "user_id" },
    { "type": "direct", "source": "actor.email", "target": "user_email" },
    { "type": "direct", "source": "actor.name", "target": "user_name" },
    { "type": "fallback", "target": "cost_usd", "sources": ["amount", "cost_usd", "cost.amount"] },
    { "type": "fallback", "target": "model", "sources": ["model", "description", "product"] },
    { "type": "direct", "source": "description", "target": "product" },
    { "type": "direct", "source": "cost_type", "target": "line_item" },
    { "type": "direct", "source": "workspace_id", "target": "project_id" },
    {
      "type": "fallback",
      "target": "id",
      "sources": ["actor.user_id", "model", "description", "starting_at", "cost_type"]
    },
    { "type": "constant", "target": "provider", "value": "anthropic" },
    { "type": "fallback", "target": "ts", "sources": ["starting_at", "ending_at"] },
    { "type": "fallback", "target": "period_start", "sources": ["starting_at"] },
    { "type": "fallback", "target": "period_end", "sources": ["ending_at"] }
  ],
  "fallbackDefinition": {
    "endpoints": [
      {
        "path": "/v1/organizations/cost_report",
        "method": "GET",
        "queryParams": {
          "starting_at": "{{sync_start_day}}",
          "ending_at": "{{sync_end_day}}",
          "bucket_width": "1d",
          "limit": "31",
          "group_by[]": "description"
        }
      }
    ],
    "pagination": {
      "type": "response_token",
      "itemsPath": "data",
      "flattenPath": "results",
      "tokenPath": "next_page",
      "tokenParam": "page",
      "pageSize": 31,
      "limitParam": "limit",
      "maxPages": 1
    },
    "fieldMappings": [
      { "type": "fallback", "target": "cost_usd", "sources": ["amount", "cost_usd", "cost.amount"] },
      { "type": "fallback", "target": "model", "sources": ["model", "description", "cost_type"] },
      { "type": "direct", "source": "description", "target": "product" },
      { "type": "direct", "source": "cost_type", "target": "line_item" },
      { "type": "direct", "source": "workspace_id", "target": "project_id" },
      {
        "type": "fallback",
        "target": "id",
        "sources": ["model", "description", "token_type", "workspace_id", "starting_at"]
      },
      { "type": "constant", "target": "provider", "value": "anthropic" },
      { "type": "fallback", "target": "ts", "sources": ["starting_at", "ending_at"] },
      { "type": "fallback", "target": "period_start", "sources": ["starting_at"] },
      { "type": "fallback", "target": "period_end", "sources": ["ending_at"] }
    ]
  },
  "validationRules": [
    { "field": "cost_usd", "type": "currency" },
    { "field": "model", "required": false, "type": "string" },
    { "field": "user_id", "required": false, "type": "string" }
  ],
  "dedupe": {
    "strategy": "period_model_user_product_cost",
    "fields": ["model", "ts", "user_id", "cost_usd", "description", "workspace_id"]
  },
  "schedule": {
    "intervalMinutes": 60,
    "enabled": true
  }
}
