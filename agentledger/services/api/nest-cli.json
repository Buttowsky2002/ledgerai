{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "connectors/presets/**/*.json", "watchAssets": true },
      { "include": "design-partner/presets/**/*.json", "watchAssets": true },
      { "include": "assets/fonts/*", "outDir": "assets/fonts", "watchAssets": true }
    ],
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": {
          "introspectComments": true,
          "dtoFileNameSuffix": [".dto.ts", ".controller.ts"]
        }
      }
    ]
  }
}
