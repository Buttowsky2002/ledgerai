// BadgerIQ control-plane Prisma schema.
//
// IMPORTANT: This schema is a *typed query client only*. The source of truth for
// the database structure is the forward-only SQL in deploy/postgres/*.sql
// (repo rule: numbered, forward-only migrations — never `prisma migrate`).
// Every model below mirrors deploy/postgres/001_core.sql; keep them in lockstep.
// FK columns are modelled as scalars (no Prisma relations yet) to keep this slice
// minimal — relations land with the CRUD task.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // The running API overrides this at runtime via PrismaService, preferring
  // BADGERIQ_PG_DSN (with LEDGERAI_* / AGENTLEDGER_* fallbacks via docker-compose).
  url      = env("BADGERIQ_PG_DSN")
}

model Tenant {
  tenantId        String   @id @default(dbgenerated("gen_random_uuid()")) @map("tenant_id") @db.Uuid
  name            String
  region          String   @default("us")
  plan            String   @default("trial")
  retentionDays   Int      @default(396) @map("retention_days")
  contentCapture  String   @default("metadata_only") @map("content_capture")
  complianceFlags Json     @default("{}") @map("compliance_flags")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("tenants")
}

model Team {
  teamId       String  @id @default(dbgenerated("gen_random_uuid()")) @map("team_id") @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  name         String
  costCenter   String? @map("cost_center")
  parentTeamId String? @map("parent_team_id") @db.Uuid
  externalId   String? @map("external_id")

  @@unique([tenantId, name])
  @@map("teams")
}

model ScimToken {
  tokenId    String    @id @default(dbgenerated("gen_random_uuid()")) @map("token_id") @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  name       String
  tokenHash  String    @map("token_hash")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz

  @@map("scim_tokens")
}

model Identity {
  userId      String @id @default(dbgenerated("gen_random_uuid()")) @map("user_id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid
  email       String
  displayName String? @map("display_name")
  teamId      String? @map("team_id") @db.Uuid
  managerId   String? @map("manager_id") @db.Uuid
  role        String @default("member")
  apiRole     String @default("viewer") @map("api_role")
  source      String @default("manual")
  aliases     Json   @default("[]")
  externalId  String? @map("external_id")
  active      Boolean @default(true)

  @@unique([tenantId, email])
  @@map("identities")
}

model TenantIdpConfig {
  idpId           String   @id @default(dbgenerated("gen_random_uuid()")) @map("idp_id") @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  protocol        String   @default("oidc")
  issuer          String
  clientId        String   @map("client_id")
  clientSecretRef String   @map("client_secret_ref")
  emailDomains    String[] @map("email_domains")
  jitEnabled      Boolean  @default(true) @map("jit_enabled")
  defaultApiRole  String   @default("viewer") @map("default_api_role")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("tenant_idp_config")
}

model App {
  appId            String  @id @default(dbgenerated("gen_random_uuid()")) @map("app_id") @db.Uuid
  tenantId         String  @map("tenant_id") @db.Uuid
  name             String
  appType          String  @default("service") @map("app_type")
  ownerUserId      String? @map("owner_user_id") @db.Uuid
  environment      String  @default("prod")
  approvedStatus   String  @default("pending") @map("approved_status")
  businessFunction String? @map("business_function")

  @@unique([tenantId, name, environment])
  @@map("apps")
}

model Agent {
  agentId          String   @id @default(dbgenerated("gen_random_uuid()")) @map("agent_id") @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  appId            String?  @map("app_id") @db.Uuid
  name             String
  runtimeType      String?  @map("runtime_type")
  ownerUserId      String?  @map("owner_user_id") @db.Uuid
  dataAccessScope  Json     @default("[]") @map("data_access_scope")
  connectedTools   Json     @default("[]") @map("connected_tools")
  approvalStatus   String   @default("pending") @map("approval_status")
  riskPosture      String   @default("unknown") @map("risk_posture")
  decommissionedAt DateTime? @map("decommissioned_at") @db.Timestamptz

  @@map("agents")
}

model AgentToolAllowlist {
  allowId   String   @id @default(dbgenerated("gen_random_uuid()")) @map("allow_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  agentId   String   @map("agent_id") @db.Uuid
  toolName  String   @map("tool_name")
  mcpServer String?  @map("mcp_server")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tenantId, agentId, toolName])
  @@map("agent_tool_allowlist")
}

model AgentCredential {
  credentialId  String    @id @default(dbgenerated("gen_random_uuid()")) @map("credential_id") @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  agentId       String    @map("agent_id") @db.Uuid
  name          String
  tokenHash     String    @map("token_hash")
  scopes        String[]  @default([])
  status        String    @default("pending")
  expiresAt     DateTime? @map("expires_at") @db.Timestamptz
  approvedBy    String?   @map("approved_by")
  approvedAt    DateTime? @map("approved_at") @db.Timestamptz
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz
  revokedReason String?   @map("revoked_reason")
  lastUsedAt    DateTime? @map("last_used_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tenantId, tokenHash])
  @@map("agent_credentials")
}

model VirtualKey {
  keyId            String    @id @default(dbgenerated("gen_random_uuid()")) @map("key_id") @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  keyHash          String    @unique @map("key_hash")
  name             String
  teamId           String?   @map("team_id") @db.Uuid
  userId           String?   @map("user_id") @db.Uuid
  appId            String?   @map("app_id") @db.Uuid
  environment      String    @default("prod")
  allowedModels    String[]  @default([]) @map("allowed_models")
  monthlyBudgetUsd Decimal?  @map("monthly_budget_usd") @db.Decimal(12, 4)
  rateLimitRpm     Int?      @map("rate_limit_rpm")
  dlpPolicyId      String?   @map("dlp_policy_id") @db.Uuid
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("virtual_keys")
}

model Policy {
  policyId  String   @id @default(dbgenerated("gen_random_uuid()")) @map("policy_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  scope     Json     @default("{}")
  kind      String
  condition Json     @default("{}")
  action    String
  severity  String   @default("medium")
  failMode  String   @default("open") @map("fail_mode")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("policies")
}

model PriceBook {
  priceId        String    @id @default(dbgenerated("gen_random_uuid()")) @map("price_id") @db.Uuid
  provider       String
  modelPrefix    String    @map("model_prefix")
  tokenType      String    @map("token_type")
  usdPerMillion  Decimal   @map("usd_per_million") @db.Decimal(12, 6)
  currency       String    @default("USD")
  effectiveStart DateTime  @map("effective_start") @db.Timestamptz
  effectiveEnd   DateTime? @map("effective_end") @db.Timestamptz
  source         String

  @@map("price_book")
}

model AllocationRule {
  ruleId         String    @id @default(dbgenerated("gen_random_uuid()")) @map("rule_id") @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  priority       Int       @default(100)
  matchingLogic  Json      @map("matching_logic")
  targetType     String    @map("target_type")
  targetId       String    @map("target_id")
  splitPct       Decimal   @default(100.00) @map("split_pct") @db.Decimal(5, 2)
  effectiveStart DateTime  @default(now()) @map("effective_start") @db.Date
  effectiveEnd   DateTime? @map("effective_end") @db.Date
  ownerUserId    String?   @map("owner_user_id") @db.Uuid

  @@map("allocation_rules")
}

model Budget {
  budgetId  String  @id @default(dbgenerated("gen_random_uuid()")) @map("budget_id") @db.Uuid
  tenantId  String  @map("tenant_id") @db.Uuid
  scopeType String  @map("scope_type")
  scopeId   String  @map("scope_id")
  period    String  @default("monthly")
  amountUsd Decimal @map("amount_usd") @db.Decimal(14, 2)
  alertPcts Int[]   @default([50, 80, 100]) @map("alert_pcts")
  hardLimit Boolean @default(false) @map("hard_limit")

  @@unique([tenantId, scopeType, scopeId, period])
  @@map("budgets")
}

model ConnectorDefinition {
  definitionId   String   @id @default(dbgenerated("gen_random_uuid()")) @map("definition_id") @db.Uuid
  tenantId       String?  @map("tenant_id") @db.Uuid
  name           String
  provider       String   @default("")
  category       String   @default("custom")
  definitionJson Json     @default("{}") @map("definition_json")
  version        Int      @default(1)
  builtIn        Boolean  @default(false) @map("built_in")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("connector_definitions")
}

model ConnectorSecret {
  secretId   String   @id @default(dbgenerated("gen_random_uuid()")) @map("secret_id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  ciphertext String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("connector_secrets")
}

model Connector {
  connectorId            String    @id @default(dbgenerated("gen_random_uuid()")) @map("connector_id") @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  kind                   String?
  connectorDefinitionId  String?   @map("connector_definition_id") @db.Uuid
  displayName            String?   @map("display_name")
  provider               String?
  category               String?
  config                 Json      @default("{}")
  secretRef              String?   @map("secret_ref")
  status                 String    @default("draft")
  enabled                Boolean   @default(true)
  mappingOverridesJson   Json      @default("{}") @map("mapping_overrides_json")
  scheduleJson           Json      @default("{}") @map("schedule_json")
  lastSyncAt             DateTime? @map("last_sync_at") @db.Timestamptz
  lastError              String?   @map("last_error")
  lastSyncStartedAt      DateTime? @map("last_sync_started_at") @db.Timestamptz
  lastSyncCompletedAt    DateTime? @map("last_sync_completed_at") @db.Timestamptz
  lastSuccessAt          DateTime? @map("last_success_at") @db.Timestamptz
  lastErrorCode          String?   @map("last_error_code")
  lastErrorMessageSafe   String?   @map("last_error_message_safe")
  syncCursor             Json      @default("{}") @map("sync_cursor")

  @@map("connectors")
}

model ConnectorSyncRun {
  syncRunId             String    @id @default(dbgenerated("gen_random_uuid()")) @map("sync_run_id") @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  connectorId           String    @map("connector_id") @db.Uuid
  status                String    @default("running")
  startedAt             DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt           DateTime? @map("completed_at") @db.Timestamptz
  recordsSeen           Int       @default(0) @map("records_seen")
  recordsImported       Int       @default(0) @map("records_imported")
  recordsRejected       Int       @default(0) @map("records_rejected")
  netSpendImportedUsd   Decimal   @default(0) @map("net_spend_imported_usd") @db.Decimal(14, 6)
  grossSpendImportedUsd Decimal   @default(0) @map("gross_spend_imported_usd") @db.Decimal(14, 6)
  requestCountImported  Int       @default(0) @map("request_count_imported")
  tokenCountImported    BigInt    @default(0) @map("token_count_imported")
  usersDetected         Int       @default(0) @map("users_detected")
  unmappedRecords       Int       @default(0) @map("unmapped_records")
  errorCode             String?   @map("error_code")
  errorMessageSafe      String?   @map("error_message_safe")

  @@map("connector_sync_runs")
}

model ConnectorSyncError {
  errorId          String   @id @default(dbgenerated("gen_random_uuid()")) @map("error_id") @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  connectorId      String   @map("connector_id") @db.Uuid
  syncRunId        String   @map("sync_run_id") @db.Uuid
  recordRef        String?  @map("record_ref")
  errorCode        String   @map("error_code")
  errorMessageSafe String   @map("error_message_safe")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("connector_sync_errors")
}

model NormalizedExternalRecord {
  recordId         String    @id @default(dbgenerated("gen_random_uuid()")) @map("record_id") @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  connectorId      String    @map("connector_id") @db.Uuid
  syncRunId        String    @map("sync_run_id") @db.Uuid
  sourceType       String    @default("api") @map("source_type")
  recordType       String    @map("record_type")
  provider         String    @default("")
  externalRecordId String?   @map("external_record_id")
  dedupeHash       String    @map("dedupe_hash")
  periodStart      DateTime? @map("period_start") @db.Timestamptz
  periodEnd        DateTime? @map("period_end") @db.Timestamptz
  ts               DateTime  @default(now()) @db.Timestamptz
  normalizedJson   Json      @default("{}") @map("normalized_json")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tenantId, connectorId, dedupeHash])
  @@map("normalized_external_records")
}

model ConnectorAttributionMapping {
  mappingId       String   @id @default(dbgenerated("gen_random_uuid()")) @map("mapping_id") @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  connectorId     String   @map("connector_id") @db.Uuid
  mappingType     String   @map("mapping_type")
  providerKey     String   @map("provider_key")
  providerKeyName String?  @map("provider_key_name")
  targetUserId    String?  @map("target_user_id")
  targetTeamId    String?  @map("target_team_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@unique([tenantId, connectorId, mappingType, providerKey])
  @@map("connector_attribution_mappings")
}

model ConnectorProviderEntity {
  entityId     String   @id @default(dbgenerated("gen_random_uuid()")) @map("entity_id") @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  connectorId  String   @map("connector_id") @db.Uuid
  entityType   String   @map("entity_type")
  providerKey  String   @map("provider_key")
  displayName  String?  @map("display_name")
  email        String?
  metadataJson Json     @default("{}") @map("metadata_json")
  lastSeenAt   DateTime @default(now()) @map("last_seen_at") @db.Timestamptz

  @@unique([tenantId, connectorId, entityType, providerKey])
  @@map("connector_provider_entities")
}

model RoiTemplate {
  templateId   String @id @default(dbgenerated("gen_random_uuid()")) @map("template_id") @db.Uuid
  tenantId     String? @map("tenant_id") @db.Uuid
  name         String
  outcomeType  String @map("outcome_type")
  sourceSystem String @map("source_system")
  valueFormula Json   @map("value_formula")
  attribution  Json   @default("{}")

  @@map("roi_templates")
}

model AuditLog {
  id     BigInt   @id @default(autoincrement())
  tenantId String @map("tenant_id") @db.Uuid
  actor  String
  action String
  object String
  detail Json     @default("{}")
  at     DateTime @default(now()) @db.Timestamptz

  @@map("audit_log")
}

model AiProviderConnection {
  connectionId      String    @id @default(dbgenerated("gen_random_uuid()")) @map("connection_id") @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  connectorId       String    @map("connector_id") @db.Uuid
  provider          String    @default("github_copilot_business")
  connectionType    String    @default("license_usage_roi") @map("connection_type")
  orgSlug           String    @map("org_slug")
  enterpriseSlug    String?   @map("enterprise_slug")
  displayName       String?   @map("display_name")
  roiAssumptions    Json      @default("{}") @map("roi_assumptions")
  scheduleJson      Json      @default("{}") @map("schedule_json")
  lastSuccessAt     DateTime? @map("last_success_at") @db.Timestamptz
  lastErrorCode     String?   @map("last_error_code")
  lastErrorMessage  String?   @map("last_error_message")
  recordsImported   Int       @default(0) @map("records_imported")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@unique([tenantId, connectorId])
  @@unique([tenantId, provider, orgSlug])
  @@map("ai_provider_connections")
}

model GithubCopilotSeat {
  seatId                  String    @id @default(dbgenerated("gen_random_uuid()")) @map("seat_id") @db.Uuid
  tenantId                String    @map("tenant_id") @db.Uuid
  connectionId            String    @map("connection_id") @db.Uuid
  orgSlug                 String    @map("org_slug")
  githubUserId            BigInt    @map("github_user_id")
  githubLogin             String    @map("github_login")
  planType                String?   @map("plan_type")
  assigningTeamSlug       String?   @map("assigning_team_slug")
  seatCreatedAt           DateTime? @map("seat_created_at") @db.Timestamptz
  pendingCancellationDate DateTime? @map("pending_cancellation_date") @db.Date
  lastActivityAt          DateTime? @map("last_activity_at") @db.Timestamptz
  lastActivityEditor      String?   @map("last_activity_editor")
  isActive                Boolean   @default(true) @map("is_active")
  monthlySeatCost         Decimal   @default(19) @map("monthly_seat_cost") @db.Decimal(14, 6)
  rawPayload              Json      @default("{}") @map("raw_payload")
  syncedAt                DateTime  @default(now()) @map("synced_at") @db.Timestamptz
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@unique([tenantId, connectionId, githubUserId])
  @@map("github_copilot_seats")
}

model GithubCopilotMember {
  memberId     String   @id @default(dbgenerated("gen_random_uuid()")) @map("member_id") @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  connectionId String   @map("connection_id") @db.Uuid
  orgSlug      String   @map("org_slug")
  githubUserId BigInt   @map("github_user_id")
  githubLogin  String   @map("github_login")
  displayName  String?  @map("display_name")
  email        String?
  avatarUrl    String?  @map("avatar_url")
  role         String?
  isOrgMember  Boolean  @default(true) @map("is_org_member")
  syncedAt     DateTime @default(now()) @map("synced_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@unique([tenantId, connectionId, githubUserId])
  @@map("github_copilot_members")
}

model GithubCopilotMemberTeam {
  memberTeamId String   @id @default(dbgenerated("gen_random_uuid()")) @map("member_team_id") @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  connectionId String   @map("connection_id") @db.Uuid
  orgSlug      String   @map("org_slug")
  githubLogin  String   @map("github_login")
  teamSlug     String   @map("team_slug")
  teamName     String   @default("") @map("team_name")
  syncedAt     DateTime @default(now()) @map("synced_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@unique([tenantId, connectionId, githubLogin, teamSlug])
  @@map("github_copilot_member_teams")
}

model GithubCopilotMemberSpendDaily {
  spendId               String   @id @default(dbgenerated("gen_random_uuid()")) @map("spend_id") @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  connectionId          String   @map("connection_id") @db.Uuid
  orgSlug               String   @map("org_slug")
  usageDate             DateTime @map("usage_date") @db.Date
  githubLogin           String   @map("github_login")
  teamSlug              String   @default("") @map("team_slug")
  seatCost              Decimal  @default(0) @map("seat_cost") @db.Decimal(14, 6)
  estimatedCreditCost   Decimal  @default(0) @map("estimated_credit_cost") @db.Decimal(14, 6)
  allocatedOverageCost  Decimal  @default(0) @map("allocated_overage_cost") @db.Decimal(14, 6)
  totalAllocatedCost    Decimal  @default(0) @map("total_allocated_cost") @db.Decimal(14, 6)
  aiCreditsUsed         Decimal  @default(0) @map("ai_credits_used") @db.Decimal(14, 6)
  linesAccepted         Int      @default(0) @map("lines_accepted")
  chatTurns             Int      @default(0) @map("chat_turns")
  prSummaryCount        Int      @default(0) @map("pr_summary_count")
  estimatedHoursSaved   Decimal  @default(0) @map("estimated_hours_saved") @db.Decimal(14, 6)
  estimatedValueCreated Decimal  @default(0) @map("estimated_value_created") @db.Decimal(14, 6)
  roiPercentage         Decimal? @map("roi_percentage") @db.Decimal(14, 6)
  utilizationStatus     String   @default("active") @map("utilization_status")
  confidenceScore       Decimal  @default(0.85) @map("confidence_score") @db.Decimal(5, 4)
  calculationVersion    String   @default("v1") @map("calculation_version")
  billedNetUsd          Decimal  @default(0) @map("billed_net_usd") @db.Decimal(14, 6)
  billedGrossUsd        Decimal  @default(0) @map("billed_gross_usd") @db.Decimal(14, 6)
  billingCredits        Decimal  @default(0) @map("billing_credits") @db.Decimal(14, 6)
  costSource            String   @default("estimate") @map("cost_source")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@unique([tenantId, connectionId, usageDate, githubLogin, teamSlug])
  @@map("github_copilot_member_spend_daily")
}

model GithubCopilotBillingLine {
  billingLineId   String   @id @default(dbgenerated("gen_random_uuid()")) @map("billing_line_id") @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  connectionId    String   @map("connection_id") @db.Uuid
  orgSlug         String   @map("org_slug")
  usageDate       DateTime @map("usage_date") @db.Date
