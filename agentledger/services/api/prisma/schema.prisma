// Idempotency ledger for POST /v1/import/events (migration 011). A re-import with
// a previously-seen (tenant_id, idempotency_key) is skipped — no double counting.
// Tenant-scoped + RLS like every other control-plane table.
model ImportIdempotency {
  tenantId       String   @map("tenant_id") @db.Uuid
  idempotencyKey String   @map("idempotency_key")
  importedAt     DateTime @default(now()) @map("imported_at") @db.Timestamptz

  @@id([tenantId, idempotencyKey])
  @@map("import_idempotency")
}
