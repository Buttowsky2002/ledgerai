#!/usr/bin/env bash
# Pre-commit secret-scanning gate using gitleaks.
#
# Install this hook: run `make install-hooks` from agentledger/.
# Requires: gitleaks >= 8  (https://github.com/gitleaks/gitleaks#installing)
#
# Fail-open when gitleaks is not installed locally — CI is the hard enforcement
# gate.  A warning is printed so developers are reminded to install it.
set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
GITLEAKS_CFG="${REPO_ROOT}/agentledger/.gitleaks.toml"

if ! command -v gitleaks &>/dev/null; then
  echo ""
  echo "  ╔══════════════════════════════════════════════════════════════╗"
  echo "  ║  WARNING: gitleaks not found — secret scan SKIPPED locally.  ║"
  echo "  ║  CI will catch secrets; install gitleaks to shift left:      ║"
  echo "  ║    brew install gitleaks   OR  go install github.com/...     ║"
  echo "  ║  Then run: make install-hooks  (from agentledger/)           ║"
  echo "  ╚══════════════════════════════════════════════════════════════╝"
  echo ""
  exit 0
fi

GITLEAKS_ARGS=(protect --staged --redact --exit-code=1 --verbose)
if [ -f "${GITLEAKS_CFG}" ]; then
  GITLEAKS_ARGS+=(--config="${GITLEAKS_CFG}")
fi

if ! gitleaks "${GITLEAKS_ARGS[@]}"; then
  echo ""
  echo "  ✗ gitleaks found potential secrets in staged changes."
  echo "    Review the findings above and remove secrets before committing."
  echo "    If this is a false positive, add an allowlist entry in:"
  echo "      agentledger/.gitleaks.toml"
  echo ""
  exit 1
fi

echo "  ✓ gitleaks: no secrets detected in staged changes."
