# Keep the build context small and free of anything sensitive or generated.
# Applies to every image built from the repo root (Dockerfile, Dockerfile.dashboard,
# services/api/Dockerfile, apps/dashboard/Dockerfile).

# VCS / CI
.git
.github
.githooks

# Secrets and local env files — never enter a build context
.env
.env.*
!.env.example

# Dependencies and build output (rebuilt inside the image)
**/node_modules
**/.next
**/dist
**/coverage
.gotmp
bin

# Docs and reports (not needed at runtime)
docs
*.md
!README.md
*.pdf
*.xlsx
*.docx

# ML training artifacts and local models (huge; never ship in app images)
ml
models

# Tests
tests
**/*.spec.ts
**/*.e2e-spec.ts

# Editor / OS noise
.vscode
.idea
.DS_Store
**/*.log
__pycache__
**/*.pyc
tmp
